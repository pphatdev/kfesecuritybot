# Telegram Bot Token from BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Gemini API Key for AI detection
GEMINI_API_KEY=your_gemini_api_key_here

# Dashboard Access Controls (Comma-separated Telegram Usernames or IDs)
# If left empty, group administrators can run /login inside their groups to access.
DASHBOARD_ADMINS=
DASHBOARD_ADMIN_IDS=
