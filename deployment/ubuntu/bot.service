[Unit]
Description=Detected Telegram Bot
After=network.target

[Service]
User=root
WorkingDirectory=/var/www/pphat/pphat.me/kfesecuritybot
Environment="PATH=/var/www/pphat/pphat.me/kfesecuritybot/.venv/bin"
ExecStart=/var/www/pphat/pphat.me/kfesecuritybot/.venv/bin/python -m app.main
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
